# AuthCorp Platform Environment Configuration
# Copy this file to .env.local for development or .env for production

# Application Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Database Configuration
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=authcorp
DB_USER=authcorp_user
DB_PASSWORD=your_secure_password_here
DB_SSL=false
DB_CONNECTION_LIMIT=10

# Alternative Database URLs (choose one)
# PostgreSQL: postgresql://username:password@localhost:5432/authcorp
# MySQL: mysql://username:password@localhost:3306/authcorp
# MongoDB: mongodb://username:password@localhost:27017/authcorp
DATABASE_URL=postgresql://authcorp_user:your_secure_password_here@localhost:5432/authcorp

# Security Configuration
JWT_SECRET=your_jwt_secret_key_here_make_it_very_long_and_random
ENCRYPTION_KEY=your_encryption_key_here_32_characters_long
SESSION_SECRET=your_session_secret_here

# API Keys for External Services
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# Risk Intelligence APIs
RISK_INTEL_API_KEY=your_risk_intelligence_api_key_here
SANCTIONS_API_KEY=your_sanctions_api_key_here
FRAUD_DATABASE_API_KEY=your_fraud_database_api_key_here

# Blockchain Configuration
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your_infura_project_id
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/your_infura_project_id
BLOCKCHAIN_PRIVATE_KEY=your_blockchain_private_key_here
CONTRAT_ADDRESS=your_smart_contract_address_here

# File Storage Configuration
STORAGE_TYPE=local
# For AWS S3
S3_BUCKET_NAME=authcorp-documents
S3_REGION=us-east-1
# For Google Cloud Storage
GCS_BUCKET_NAME=authcorp-documents
GCS_PROJECT_ID=your_gcs_project_id
# For Azure Blob Storage
AZURE_STORAGE_ACCOUNT=your_azure_storage_account
AZURE_STORAGE_KEY=your_azure_storage_key
AZURE_CONTAINER_NAME=authcorp-documents

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
FROM_EMAIL=noreply@authcorp.com

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# Monitoring and Analytics
SENTRY_DSN=your_sentry_dsn_here
GOOGLE_ANALYTICS_ID=your_google_analytics_id
MIXPANEL_TOKEN=your_mixpanel_token

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Limits
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/tiff,application/pdf

# AI Model Configuration
AI_MODEL_ENDPOINT=http://localhost:8000
AI_MODEL_API_KEY=your_ai_model_api_key
DEEPFAKE_DETECTION_THRESHOLD=0.7
FORGERY_DETECTION_THRESHOLD=0.8

# OCR Configuration
TESSERACT_PATH=/usr/bin/tesseract
OCR_LANGUAGES=eng,fra,deu,spa,ita

# Compliance and Audit
AUDIT_LOG_RETENTION_DAYS=2555
DATA_RETENTION_DAYS=2555
GDPR_COMPLIANCE=true
CCPA_COMPLIANCE=true
HIPAA_COMPLIANCE=false

# Development Only
DEBUG_MODE=false
LOG_LEVEL=info
ENABLE_SWAGGER=false

# Production Security Headers
CSP_POLICY="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:;"
HSTS_MAX_AGE=31536000
X_FRAME_OPTIONS=DENY

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_TYPE=s3
BACKUP_ENCRYPTION_KEY=your_backup_encryption_key

# Load Balancing and Clustering
CLUSTER_MODE=false
WORKER_PROCESSES=auto
LOAD_BALANCER_IP=127.0.0.1

# Feature Flags
ENABLE_BLOCKCHAIN_ANCHORING=true
ENABLE_AR_FORENSICS=true
ENABLE_AI_ASSISTANT=true
ENABLE_REAL_TIME_MONITORING=true
ENABLE_ADVANCED_ANALYTICS=true